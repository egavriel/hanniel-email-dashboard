{
  "name": "hanniel-email-dashboard",
  "compatibility_date": "2025-03-20",
  "compatibility_flags": ["nodejs_compat"],
  "main": ".open-next/worker.js",
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "hanniel-email-meta",
      "database_id": "ef30d746-2504-4def-b117-9728d59412cf"
    }
  ]
}
